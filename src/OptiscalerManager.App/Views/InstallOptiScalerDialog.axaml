<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerManager.App.Views.InstallOptiScalerDialog"
        Width="680" Height="720" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBgBase}"
        Title="Install OptiScaler">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">

    <StackPanel Grid.Row="0" Spacing="4">
      <TextBlock Name="TitleText" FontSize="18" FontWeight="Bold"
                 Foreground="{StaticResource BrTextPrimary}"/>
      <TextBlock Text="Choose the FSR 4 backend and OptiScaler.ini to use. Nothing is written until you confirm — the preview below is exactly what will happen."
                 FontSize="12" Foreground="{StaticResource BrTextSecondary}" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Options -->
    <StackPanel Grid.Row="1" Spacing="14" Margin="0,14,0,0">

      <StackPanel Spacing="6">
        <TextBlock Text="1. Backend — which files to install" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}"/>
        <Border Padding="12" CornerRadius="8" Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="1">
          <StackPanel Spacing="6">
            <RadioButton Name="RbAmdSdk" GroupName="Fsr4" Content="Latest FSR SDK from AMD (swap in place)"
                         Foreground="{StaticResource BrTextPrimary}"
                         ToolTip.Tip="Download AMD's SIGNED prebuilt FSR DLLs from the official FidelityFX-SDK repository (Kits/FidelityFX/signedbin) — the exact artifacts OptiScaler bundles, at AMD's newest revision (can be newer than the snapshot OptiScaler pins) — and swap OptiScaler's matching files in place. Nothing new is added."/>

            <RadioButton Name="RbInt8" GroupName="Fsr4" Content="FSR 4 INT8 (community build)"
                         Foreground="{StaticResource BrTextPrimary}"
                         ToolTip.Tip="Install a community FSR 4 INT8 build (amd_fidelityfx_upscaler_dx12.dll) from the OptiScaler-Extras repo, at the version you pick below. This is the option that provides FSR 4 without a driver."/>
            <StackPanel Name="Int8VersionPanel" Orientation="Horizontal" Spacing="8" Margin="26,0,0,0" IsVisible="False">
              <TextBlock Text="Version:" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
              <ComboBox Name="Int8VersionCombo" MinWidth="180"
                        ToolTip.Tip="Which INT8 community build to install (newest first). Populated from the OptiScaler-Extras repo."/>
            </StackPanel>

            <RadioButton Name="RbCustomMerged" GroupName="Fsr4" Content="Custom DLLs + latest AMD SDK (merged)"
                         Foreground="{StaticResource BrTextPrimary}"
                         ToolTip.Tip="The latest AMD signedbin files as the base, with your imported custom DLLs merged on top: same-name DLLs overwrite AMD's, unknown names (e.g. amdxcffx64.dll) are added alongside. Import your DLLs in Settings; Revert removes everything."/>
            <RadioButton Name="RbDefault" GroupName="Fsr4" Content="Default — OptiScaler's own files (includes FSR 4.1, recommended)"
                         Foreground="{StaticResource BrTextPrimary}"
                         ToolTip.Tip="Install OptiScaler exactly as its release ships it. OptiScaler already bundles a working FSR 4.1 upscaler, so this alone enables FSR 4 — no extra downloads or swaps."/>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="2. FSR 4 selection" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}"/>
        <Border Padding="12" CornerRadius="8" Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="FSR 4 is always made available (Fsr4Update=true). This only decides whether it is pre-selected."
                       FontSize="11" Foreground="{StaticResource BrTextSecondary}" TextWrapping="Wrap"/>
            <RadioButton Name="RbSelectNow" GroupName="Fsr4Select" Content="Select FSR 4 for me now (UpscalerIndex=0)"
                         Foreground="{StaticResource BrTextPrimary}" IsChecked="True"
                         ToolTip.Tip="OptiScaler Manager sets [FSR] UpscalerIndex=0 so FSR 4 is active immediately."/>
            <RadioButton Name="RbSelectInGame" GroupName="Fsr4Select" Content="I'll select it in-game (UpscalerIndex=auto)"
                         Foreground="{StaticResource BrTextPrimary}"
                         ToolTip.Tip="Leaves [FSR] UpscalerIndex=auto so you can choose the upscaler from OptiScaler's in-game overlay."/>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="OptiScaler.ini" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}"/>
        <ComboBox Name="ProfileCombo" HorizontalAlignment="Stretch"
                  ToolTip.Tip="Base OptiScaler.ini to write. The Manager only overrides the keys above; everything else in the chosen .ini is left intact. Import your own tagged .ini files in Settings."/>
      </StackPanel>
    </StackPanel>

    <!-- Live preview -->
    <Border Grid.Row="2" Margin="0,14,0,0" CornerRadius="8"
            Background="{StaticResource BrBgCard}"
            BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="1">
      <ScrollViewer Margin="12">
        <StackPanel Spacing="14">
          <Border Name="ConflictBox" IsVisible="False" Padding="10" CornerRadius="6"
                  Background="#3D1F1F" BorderBrush="{StaticResource BrError}" BorderThickness="1">
            <StackPanel Name="ConflictList" Spacing="3"/>
          </Border>

          <StackPanel Spacing="6">
            <TextBlock Text="Files written next to the game executable" FontWeight="SemiBold"
                       Foreground="{StaticResource BrTextPrimary}"/>
            <StackPanel Name="FilesList" Spacing="3"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="OptiScaler.ini keys that will be set" FontWeight="SemiBold"
                       Foreground="{StaticResource BrTextPrimary}"/>
            <StackPanel Name="IniList" Spacing="3"/>
          </StackPanel>

          <TextBlock Text="Existing files are backed up to an external per-game store before being overwritten, so Revert can restore them."
                     FontSize="11" Foreground="{StaticResource BrTextSecondary}" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="10" Margin="0,16,0,0">
      <Button Content="Cancel" Click="OnCancel"/>
      <Button Name="ConfirmButton" Classes="BtnPrimary" Content="Confirm and install" Click="OnConfirm"/>
    </StackPanel>
  </Grid>
</Window>
