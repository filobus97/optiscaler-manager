<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OptiscalerManager.App.ViewModels"
        x:Class="OptiscalerManager.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="880" Height="640" MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrBgBase}"
        XYFocus.NavigationModes="Keyboard,Gamepad"
        Title="OptiScaler Manager">

  <Window.Styles>
    <!-- The focused/selected game row lights up its card border. -->
    <Style Selector="ListBoxItem:selected Border.GameCard">
      <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
    </Style>
    <Style Selector="ListBoxItem:focus-visible Border.GameCard">
      <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="20">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
      <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
        <TextBlock Text="OptiScaler Manager" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource BrTextPrimary}"/>
        <TextBlock Text="Install OptiScaler and get FSR 4 working in your games — the simple way."
                   FontSize="13" Foreground="{StaticResource BrTextSecondary}"/>
      </StackPanel>
      <Button Grid.Column="1" Name="RescanButton" Content="Rescan"
              Click="OnRescanClick" Margin="0,0,8,0"
              IsEnabled="{Binding IsIdle}"
              ToolTip.Tip="Re-scan your libraries (Steam, Epic, GOG, Xbox, EA, Battle.net, Ubisoft) for installed games."/>
      <Button Grid.Column="2" Name="SettingsButton" Content="Settings"
              Click="OnSettingsClick"
              ToolTip.Tip="Import your own DLLs and .ini profiles, and set the OptiScaler overlay/menu key."/>
    </Grid>

    <!-- GPU banner -->
    <Border Grid.Row="1" Margin="0,16,0,0" Padding="14,10"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource BrBgCard}"
            BorderThickness="1" BorderBrush="{StaticResource BrBorderSubtle}">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                Background="{Binding GpuBrush}"/>
        <TextBlock Text="{Binding GpuText}" VerticalAlignment="Center"
                   Foreground="{StaticResource BrTextPrimary}" FontWeight="SemiBold"/>
      </StackPanel>
    </Border>

    <!-- Update-available banner (hidden unless a newer release exists) -->
    <Border Grid.Row="2" Name="UpdateBanner" IsVisible="False" Margin="0,10,0,0" Padding="12,8"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="#2A2440"
            BorderThickness="1" BorderBrush="{StaticResource BrAccent}">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Name="UpdateBannerText" Grid.Column="0" VerticalAlignment="Center"
                   Foreground="{StaticResource BrTextPrimary}" FontSize="12" TextWrapping="Wrap"/>
        <Button Grid.Column="1" Name="UpdateNowButton" Classes="BtnPrimary" Content="Update now" FontSize="11" Margin="8,0,0,0"
                Click="OnUpdateNowClick"
                ToolTip.Tip="Closes the app, updates it in place, and reopens it automatically. Your settings, imports, profiles and backups are kept."/>
        <Button Grid.Column="2" Content="Open releases page" FontSize="11" Margin="8,0"
                Click="OnOpenReleasesClick"
                ToolTip.Tip="Opens this app's GitHub releases page in your browser to read what changed."/>
        <Button Grid.Column="3" Content="✕" FontSize="11" Padding="8,4"
                Click="OnDismissUpdateBanner" ToolTip.Tip="Hide until next launch."/>
      </Grid>
    </Border>

    <!-- Bring-your-own summary -->
    <Border Grid.Row="3" Margin="0,10,0,0" Padding="12,8"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource BrBgSurface}"
            BorderThickness="1" BorderBrush="{StaticResource BrBorderSubtle}"
            ToolTip.Tip="Custom FSR components and OptiScaler.ini profiles you have imported. Select them per-install in the Install OptiScaler dialog.">
      <TextBlock Text="{Binding ImportSummary}" Foreground="{StaticResource BrTextSecondary}"
                 FontSize="12" TextWrapping="Wrap"/>
    </Border>

    <!-- Game list -->
    <Border Grid.Row="4" Margin="0,12,0,0"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource BrBgCard}"
            BorderThickness="1" BorderBrush="{StaticResource BrBorderSubtle}">
      <Grid>
        <!-- ListBox (not ItemsControl) so Up/Down walks the game rows with the
             keyboard/controller; the focused row's buttons are one Right away. -->
        <ListBox Name="GamesList" ItemsSource="{Binding Games}" Margin="8"
                 Background="Transparent" SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:GameRowViewModel">
              <Border Classes="GameCard" Padding="14,12"
                      CornerRadius="{StaticResource RadiusMedium}"
                      Background="{StaticResource BrBgSurface}"
                      BorderThickness="1" BorderBrush="{StaticResource BrBorderSubtle}">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                               Foreground="{StaticResource BrTextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding SubTitle}" FontSize="11"
                               Foreground="{StaticResource BrTextSecondary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="{StaticResource BrAccent}"/>
                  </StackPanel>

                  <Button Grid.Column="1" Classes="BtnPrimary" Content="Install OptiScaler"
                          Margin="0,0,8,0" Click="OnInstallClick"
                          IsEnabled="{Binding IsIdle}"
                          ToolTip.Tip="Download and install OptiScaler for this game. The next dialog lets you choose the version, backend, add-ons and OptiScaler.ini — and shows exactly what will change before anything is written."/>
                  <Button Grid.Column="2" Classes="BtnDanger" Content="Revert"
                          Click="OnRevertClick"
                          IsEnabled="{Binding IsIdle}"
                          ToolTip.Tip="Uninstall OptiScaler from this game: restore backed-up files and remove everything the install added. Reports if there is nothing to revert."/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock IsVisible="{Binding HasNoGames}" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource BrTextSecondary}" TextAlignment="Center"
                   Text="No games detected yet.&#x0a;Click Rescan, or import your own DLLs from Settings."/>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="5" Margin="0,12,0,0" Padding="12,8"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource BrBgSurface}">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                   Foreground="{StaticResource BrTextSecondary}" FontSize="12"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
